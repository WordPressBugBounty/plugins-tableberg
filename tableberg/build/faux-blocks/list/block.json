{
  "$schema": "https://schemas.wp.org/trunk/block.json",
  "apiVersion": 3,
  "name": "tableberg/list",
  "title": "List",
  "category": "design",
  "description": "A list element within a Tableberg cell",
  "parent": [
    "tableberg/cell"
  ],
  "attributes": {
    "cellCoords": {
      "type": "object",
      "default": {
        "row": 0,
        "col": 0
      }
    },
    "elementIndex": {
      "type": "number",
      "default": 0
    }
  },
  "supports": {
    "html": false,
    "customClassName": false,
    "lock": false,
    "renaming": false,
    "reusable": false,
    "visibility": false
  },
  "textdomain": "tableberg"
}